---
---

<section class="contact-section">
  <div class="page-container">
    <div class="contact-layout">
      <div class="form-wrapper">
        <trailhand-form-card shadow>
          <trailhand-form-row columns="2">
            <trailhand-text-input
              name="name"
              label="Name"
              placeholder="Your name"
              required
            ></trailhand-text-input>
            <trailhand-text-input
              name="email"
              type="email"
              label="Email"
              placeholder="email@address.com"
              required
            ></trailhand-text-input>
          </trailhand-form-row>

          <trailhand-form-row>
            <trailhand-text-input
              name="company"
              label="Company"
              placeholder="Your company"
            ></trailhand-text-input>
          </trailhand-form-row>

          <trailhand-form-row>
            <trailhand-text-area
              name="message"
              label="How can we help?"
              placeholder="Tell us about your project..."
              required
              rows="5"
            ></trailhand-text-area>
          </trailhand-form-row>
        </trailhand-form-card>
      </div>

      <div class="contact-header">
        <h2 class="section-title">Get in Touch</h2>
        <p class="section-subtitle">
          Interested in Epinio support or professional services? We'd love to hear from you.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import '@krumio/trailhand-ui/components/th-form-card';
  import '@krumio/trailhand-ui/components/text-input';
  import '@krumio/trailhand-ui/components/text-area';
</script>

<style>
  .contact-section {
    background-color: var(--epinio-secondary-background-color);
    padding: 80px 0;
  }

  .contact-layout {
    display: flex;
    align-items: flex-start;
    gap: 64px;
  }

  .contact-header {
    flex: 0 0 300px;
    padding-top: 8px;
  }

  .section-title {
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-weight: 600;
    color: var(--epinio-primary-dark);
    margin: 0 0 16px;
  }

  .section-subtitle {
    font-size: 1rem;
    color: var(--epinio-grayscale-600);
    margin: 0;
    line-height: 1.6;
  }

  .form-wrapper {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .contact-layout {
      flex-direction: column;
      gap: 32px;
    }

    .contact-header {
      flex: none;
    }
  }
</style>
