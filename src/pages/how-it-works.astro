  }

  /* ── Persona Toggle ─────────────────────────────────────────── */
  .persona-toggle {
    display: inline-flex;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    padding: 4px;
    gap: 4px;
  }

  .persona-btn {
    background: none;
    border: none;
    border-radius: 50px;
    padding: 10px 28px;
    font-family: var(--epinio-font-family);
    font-size: 14px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.65);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .persona-btn--active,
  .persona-btn:hover {
    background-color: var(--epinio-primary-color);
    color: #ffffff;
  }

  /* ── Stages ─────────────────────────────────────────────────── */
  .stage {
    padding: 80px 0;
  }

  .stage--white {
    background-color: var(--epinio-background-color);
  }

  .stage--gray {
    background-color: var(--epinio-secondary-background-color);
  }

  .stage-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  .stage-row--reversed .stage-copy {
    order: 2;
  }

