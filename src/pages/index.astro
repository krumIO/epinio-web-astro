---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import GetStartedSection from '../components/GetStartedSection.astro';
import { getImage } from "astro:assets";
import heroBg from "../assets/images/epinio-background-hero.svg";
import dashboardImage from "../assets/images/epinio-dashboard.png";
import WhereEpinioHelpsSection from '../components/WhereEpinioHelpsSection.astro';
import WhatsNewSection from '../components/WhatsNewSection.astro';
import ContactSection from '../components/ContactSection.astro';

const optimizedHero = await getImage({ src: heroBg, format: "svg" });
const optimizedDashboard = await getImage({ src: dashboardImage, format: "png" });

const title = "Epinio";
const description = "Epinio is an Application Development Engine for Kubernetes. Deploy and manage applications with a single command.";
---

<Layout title={title} description={description}>
  <main>

    <HeroSection
      backgroundImage={optimizedHero.src}
      heroImage={optimizedDashboard.src}
      heroImageAlt="Epinio dashboard"
      title="The Application Development Engine for Kubernetes"
      subtitle="Tame your developer workflow to go from Code to URL in one push."
      description="Epinio installs into any Kubernetes cluster to bring your application from source code to deployment and allow for Developers and Operators to work better together!"
    >
      <a slot="actions" href="https://docs.epinio.io" class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Get Started
      </a>
      <a slot="actions" href="https://github.com/epinio/epinio/" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
        GitHub
      </a>
    </HeroSection>

    <GetStartedSection sectionTitle="Get Started with Epinio">
      <li slot="steps">Get access to a Kubernetes cluster. Install cert-manager if not already present.</li>
      <li slot="steps">Install Epinio in the cluster using Helm.</li>
      <li slot="steps">Open the Web UI, or install the Epinio client for operation from a terminal.</li>
      <li slot="steps">Log into the cluster.</li>
      <li slot="steps">Push your application. Epinio builds the application image for you.</li>

      <trailhand-card
        slot="card"
        class="installation-card"
        card-title="Installation Guide"
        description="Everything you need to get Epinio running on your Kubernetes cluster."
        icon-name="rocket"
      >
        <a slot="action" href="https://docs.epinio.io/installation/install_epinio" target="_blank" rel="noopener noreferrer">
          <trailhand-button variant="secondary" size="large" class="install-button">
            View Installation Docs
          </trailhand-button>
        </a>
      </trailhand-card>
    </GetStartedSection>
    <WhereEpinioHelpsSection />
    <WhatsNewSection />
    <ContactSection />
</main>
</Layout>

<style>
  /* Hero button styles */
  .btn {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .btn-primary {
    background-color: var(--epinio-primary-color);
    color: var(--epinio-white-text-color);
  }

  .btn-primary:hover {
    background-color: var(--epinio-primary-dark);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--epinio-white-text-color);
    border: 2px solid var(--epinio-grayscale-400);
  }

  .btn-secondary:hover {
    border-color: var(--epinio-white-text-color);
  }

  /* Card theming */
  .installation-card {
    --th-card-bg: #fbfbfb;
    --th-card-border: #e4e4e4;
    --th-card-title-color: var(--epinio-primary-color);
    --th-card-text-color: var(--epinio-grayscale-600);
  }

  .install-button {
    --th-button-secondary-color: var(--epinio-primary-color);
    width: 100%;
  }

  /* Card footer slot styles */
  .footer-heading {
    margin: 0 0 12px;
    font-size: 14px;
    font-weight: 600;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
  }

  .footer-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #3b82f6;
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid #e5e7eb;
    font-size: 14px;
  }

  .footer-link:last-child {
    border-bottom: none;
  }

  .footer-link:hover {
    color: #2563eb;
  }
</style>
